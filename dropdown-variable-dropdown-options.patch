+
+        $("#dropdownItemsContainer").on("click", ".remove-dropdown-item", function () {
+            $(this).closest(".dropdown-option-item").remove();
+        });
+
+        $("#configureDropdownForm").on("submit", function () {
+            updateDropdownOptionsField();
+        });
