     <script>
+        function buildDropdownItem(value = "") {
+            return $("<div class=\"input-group dropdown-option-item mb-2\">")
+                .append("<input type=\"text\" class=\"form-control dropdown-option-value\" value=\"" + $("<div/>").text(value).html() + "\" />")
+                .append("<span class=\"input-group-btn\"><button type=\"button\" class=\"btn btn-danger remove-dropdown-item\">Remove</button></span>");
+        }
+
+        function updateDropdownOptionsField() {
+            const values = [];
+            $("#dropdownItemsContainer .dropdown-option-value").each(function () {
+                const value = $(this).val();
+                if (value !== undefined && value !== null && value.toString().trim().length > 0) {
+                    values.push(value.toString());
+                }
+            });
+            $("#dropdownOptionsInput").val(JSON.stringify(values));
+        }
+
+        function populateDropdownItems(options) {
+            const container = $("#dropdownItemsContainer").empty();
+            (options || []).forEach(function (option) {
+                container.append(buildDropdownItem(option));
+            });
+        }
+
+        function setConfigureDropdownFormAction(variableId) {
+            if (!variableId) {
+                $("#configureDropdownForm").attr("action", "#");
+                return;
+            }
+
+            $("#configureDropdownForm").attr("action", "{{ route('admin.nests.egg.variables.edit', ['egg' => $egg->id, 'variable' => 'VARIABLE_ID']) }}".replace('VARIABLE_ID', variableId));
+        }
+
+        $("#dropdownVariableSelect").on("change", function () {
+            const selected = $(this).find("option:selected");
+            const options = selected.data("dropdown-options") || [];
+            populateDropdownItems(Array.isArray(options) ? options : []);
+            setConfigureDropdownFormAction($(this).val());
+        });
+
+        $("#addDropdownItem").on("click", function () {
+            $("#dropdownItemsContainer").append(buildDropdownItem(''));
