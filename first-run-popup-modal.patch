+<?php
+
+namespace Pterodactyl\Http\Requests\Admin\Egg;
+
+use Pterodactyl\Http\Requests\Admin\AdminFormRequest;
+
+class EggPopupFormRequest extends AdminFormRequest
+{
+    public function rules(): array
+    {
+        return [
+            'first_run_popup_title' => 'nullable|string|max:191',
+            'first_run_popup_content' => 'nullable|string',
+        ];
+    }
+
+    public function validated($key = null, $default = null): array
+    {
+        $data = parent::validated();
+
+        $title = trim((string) array_get($data, 'first_run_popup_title', ''));
+        $content = trim((string) array_get($data, 'first_run_popup_content', ''));
+
+        return [
+            'first_run_popup_title' => $title === '' ? null : $title,
+            'first_run_popup_content' => $content === '' ? null : $content,
+        ];
+    }
+}
