diff --git a/resources/scripts/components/server/features/FirstRunPopupFeature.tsx b/resources/scripts/components/server/features/FirstRunPopupFeature.tsx
new file mode 100644
--- /dev/null
+++ b/resources/scripts/components/server/features/FirstRunPopupFeature.tsx
@@ -0,0 +1,48 @@
+import React, { useMemo, useState } from 'react';
+import { ServerContext } from '@/state/server';
+import Modal from '@/components/elements/Modal';
+import tw from 'twin.macro';
+import Button from '@/components/elements/Button';
+
+const storageKey = (identifier: string) => `ptero:first-run-popup:${identifier}`;
+
+const FirstRunPopupFeature = () => {
+    const serverIdentifier = ServerContext.useStoreState((state) => state.server.data!.identifier);
+    const title = ServerContext.useStoreState((state) => state.server.data!.firstRunPopupTitle);
+    const content = ServerContext.useStoreState((state) => state.server.data!.firstRunPopupContent);
+
+    const hasPopupContent = useMemo(() => {
+        return Boolean((title && title.trim().length > 0) || (content && content.trim().length > 0));
+    }, [title, content]);
+
+    const [visible, setVisible] = useState(() => {
+        if (!hasPopupContent) {
+            return false;
+        }
+
+        return localStorage.getItem(storageKey(String(serverIdentifier))) !== '1';
+    });
+
+    if (!hasPopupContent) {
+        return null;
+    }
+
+    const dismiss = () => {
+        localStorage.setItem(storageKey(String(serverIdentifier)), '1');
+        setVisible(false);
+    };
+
+    return (
+        <Modal visible={visible} onDismissed={dismiss} closeOnBackground={false}>
+            <h2 css={tw`text-2xl mb-4 text-neutral-100`}>{title || 'Welcome'}</h2>
+            <p css={tw`text-neutral-200 whitespace-pre-line`}>{content || ''}</p>
+            <div css={tw`mt-8 sm:flex items-center justify-end`}>
+                <Button onClick={dismiss} css={tw`w-full sm:w-auto`}>
+                    Continue
+                </Button>
+            </div>
+        </Modal>
+    );
+};
+
+export default FirstRunPopupFeature;
