@@ -0,0 +1,144 @@
+<?php
+
+namespace Pterodactyl\Http\Controllers\Admin\Nests;
+
+use Illuminate\View\View;
+use Pterodactyl\Models\Egg;
+use Illuminate\Http\RedirectResponse;
+use Illuminate\Support\Facades\Schema;
+use Prologue\Alerts\AlertsMessageBag;
+use Pterodactyl\Http\Controllers\Controller;
+use Pterodactyl\Services\Eggs\EggUpdateService;
+use Pterodactyl\Http\Requests\Admin\Egg\EggPopupFormRequest;
+
+class EggPopupController extends Controller
+{
+    private const POPUPS = [
+        'on_first_start' => [
+            'name' => 'On First Start',
+            'description' => 'Shown once when a user first opens the server console.',
+            'title_field' => 'popup_on_first_start_title',
+            'content_field' => 'popup_on_first_start_content',
+            'legacy_title_field' => 'first_run_popup_title',
+            'legacy_content_field' => 'first_run_popup_content',
+        ],
+        'on_console_error' => [
+            'name' => 'On Console Error Message',
+            'description' => 'Shown when an error-like line is detected in console output.',
+            'title_field' => 'popup_on_console_error_title',
+            'content_field' => 'popup_on_console_error_content',
+            'legacy_title_field' => null,
+            'legacy_content_field' => null,
+        ],
+    ];
+
+    public function __construct(
+        private readonly AlertsMessageBag $alert,
+        private readonly EggUpdateService $updateService,
+    ) {
+    }
+
+    /**
+     * Show the popup list for an egg.
+     */
+    public function index(Egg $egg): View
+    {
+        $popups = collect(self::POPUPS)->map(function (array $popup, string $key) use ($egg) {
+            $fields = $this->resolveStorageFields($popup);
+
+            return array_merge($popup, [
+                'key' => $key,
+                'is_configured' => filled($this->getEggFieldValue($egg, $fields['title'])) || filled($this->getEggFieldValue($egg, $fields['content'])),
+            ]);
+        })->values();
+
+        return view('admin.eggs.popups', [
+            'egg' => $egg,
+            'popups' => $popups,
+        ]);
+    }
+
+    /**
+     * Show popup settings for a specific popup key.
+     */
+    public function view(Egg $egg, string $popupKey): View
+    {
+        $popup = $this->resolvePopup($popupKey);
+        $fields = $this->resolveStorageFields($popup);
+
+        return view('admin.eggs.popup', [
+            'egg' => $egg,
+            'popup' => $popup,
+            'popupKey' => $popupKey,
+            'titleValue' => $this->getEggFieldValue($egg, $fields['title']),
+            'contentValue' => $this->getEggFieldValue($egg, $fields['content']),
+        ]);
+    }
+
+    /**
+     * Update popup modal settings for an egg.
+     *
+     * @throws \Pterodactyl\Exceptions\Model\DataValidationException
+     * @throws \Pterodactyl\Exceptions\Repository\RecordNotFoundException
+     * @throws \Pterodactyl\Exceptions\Service\Egg\NoParentConfigurationFoundException
+     */
+    public function update(EggPopupFormRequest $request, Egg $egg, string $popupKey): RedirectResponse
+    {
+        $popup = $this->resolvePopup($popupKey);
+        $fields = $this->resolveStorageFields($popup);
+        $data = $request->validated();
+        $payload = [];
+
+        if (!is_null($fields['title'])) {
+            $payload[$fields['title']] = $data['title'];
+        }
+
+        if (!is_null($fields['content'])) {
+            $payload[$fields['content']] = $data['content'];
+        }
+
+        if (empty($payload)) {
+            $this->alert->warning('Popup columns are not available yet. Run database migrations and try again.')->flash();
+
+            return redirect()->route('admin.nests.egg.popup.view', [$egg->id, $popupKey]);
+        }
+
+        $this->updateService->handle($egg, $payload);
+        $this->alert->success(trans('admin/nests.eggs.notices.updated'))->flash();
+
+        return redirect()->route('admin.nests.egg.popup.view', [$egg->id, $popupKey]);
+    }
+
+    private function resolvePopup(string $popupKey): array
+    {
+        abort_unless(array_key_exists($popupKey, self::POPUPS), 404);
+
+        return self::POPUPS[$popupKey];
+    }
+
+    private function resolveStorageFields(array $popup): array
+    {
+        $title = $popup['title_field'];
+        $content = $popup['content_field'];
+
+        if (Schema::hasColumn('eggs', $title) && Schema::hasColumn('eggs', $content)) {
+            return ['title' => $title, 'content' => $content];
+        }
+
+        $legacyTitle = $popup['legacy_title_field'];
+        $legacyContent = $popup['legacy_content_field'];
+        if (!is_null($legacyTitle) && !is_null($legacyContent)
+            && Schema::hasColumn('eggs', $legacyTitle)
+            && Schema::hasColumn('eggs', $legacyContent)
+        ) {
+            return ['title' => $legacyTitle, 'content' => $legacyContent];
+        }
+
+        return ['title' => null, 'content' => null];
+    }
+
+    private function getEggFieldValue(Egg $egg, ?string $field): ?string
+    {
+        return is_null($field) ? null : $egg->{$field};
+    }
+}
