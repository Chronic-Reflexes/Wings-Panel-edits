index 0000000..e5c41f1
--- /dev/null
+++ b/resources/scripts/components/server/features/FirstRunPopupFeature.tsx
@@ -0,0 +1,169 @@
+import React, { useEffect, useMemo, useRef, useState } from 'react';
+import { ServerContext } from '@/state/server';
+import Modal from '@/components/elements/Modal';
+import tw from 'twin.macro';
+import Button from '@/components/elements/Button';
+import { SocketEvent } from '@/components/server/events';
+
+type PopupMode = 'on_first_start' | 'on_console_error';
+
+const storageKey = (identifier: string, mode: PopupMode) => `ptero:popup-modal:${mode}:${identifier}`;
+const powerActionKey = (identifier: string) => `ptero:popup-modal:power_action:${identifier}`;
+
+const hasValue = (value: string | null) => Boolean(value && value.trim().length > 0);
+
+const isErrorLikeLine = (line: string) => /(error|exception|fatal|failed|panic|traceback)/i.test(line);
+
+const FirstRunPopupFeature = () => {
+    const serverIdentifier = ServerContext.useStoreState((state) => state.server.data!.identifier);
+    const runtimeStatus = ServerContext.useStoreState((state) => state.status.value);
+    const firstStartTitle = ServerContext.useStoreState((state) => state.server.data!.popupOnFirstStartTitle);
+    const firstStartContent = ServerContext.useStoreState((state) => state.server.data!.popupOnFirstStartContent);
+    const errorTitle = ServerContext.useStoreState((state) => state.server.data!.popupOnConsoleErrorTitle);
+    const errorContent = ServerContext.useStoreState((state) => state.server.data!.popupOnConsoleErrorContent);
+    const { connected, instance } = ServerContext.useStoreState((state) => state.socket);
+
+    const hasFirstStartPopup = useMemo(
+        () => hasValue(firstStartTitle) || hasValue(firstStartContent),
+        [firstStartTitle, firstStartContent]
+    );
+
+    const hasConsoleErrorPopup = useMemo(
+        () => hasValue(errorTitle) || hasValue(errorContent),
+        [errorTitle, errorContent]
+    );
+
+    const [activePopup, setActivePopup] = useState<PopupMode | null>(null);
+    const hasSeenNonRunningSinceMount = useRef(runtimeStatus !== 'running');
+    const hasSeenPowerActionSinceMount = useRef(localStorage.getItem(powerActionKey(String(serverIdentifier))) === '1');
+
+    useEffect(() => {
+        if (!hasFirstStartPopup) {
+            return;
+        }
+
+        if (runtimeStatus === 'installing' || runtimeStatus === 'install_failed' || runtimeStatus === 'reinstall_failed') {
+            localStorage.removeItem(storageKey(String(serverIdentifier), 'on_first_start'));
+            localStorage.removeItem(powerActionKey(String(serverIdentifier)));
+            hasSeenPowerActionSinceMount.current = false;
+        }
+    }, [serverIdentifier, runtimeStatus, hasFirstStartPopup]);
+
+    useEffect(() => {
+        if (runtimeStatus && runtimeStatus !== 'running') {
+            hasSeenNonRunningSinceMount.current = true;
+        }
+    }, [runtimeStatus]);
+
+    useEffect(() => {
+        const identifier = String(serverIdentifier);
+
+        if (localStorage.getItem(powerActionKey(identifier)) === '1') {
+            hasSeenPowerActionSinceMount.current = true;
+        }
+
+        if (
+            hasFirstStartPopup
+            && runtimeStatus === 'running'
+            && hasSeenNonRunningSinceMount.current
+            && hasSeenPowerActionSinceMount.current
+            && localStorage.getItem(storageKey(identifier, 'on_first_start')) !== '1'
+        ) {
+            setActivePopup((current) => current ?? 'on_first_start');
+        }
+    }, [serverIdentifier, runtimeStatus, hasFirstStartPopup]);
+
+    useEffect(() => {
+        if (!connected || !instance) {
+            return;
+        }
+
+        const identifier = String(serverIdentifier);
+        const firstStartPopupStorageKey = storageKey(identifier, 'on_first_start');
+
+        const handleInstallStarted = () => {
+            // Reinstall should count as a fresh first run.
+            localStorage.removeItem(firstStartPopupStorageKey);
+            localStorage.removeItem(powerActionKey(identifier));
+            hasSeenNonRunningSinceMount.current = true;
+            hasSeenPowerActionSinceMount.current = false;
+        };
+
+        const handleServerStatus = (status: string) => {
+            if (status !== 'running') {
+                hasSeenNonRunningSinceMount.current = true;
+                return;
+            }
+
+            if (
+                !hasFirstStartPopup
+                || activePopup
+                || !hasSeenNonRunningSinceMount.current
+                || !hasSeenPowerActionSinceMount.current
+                || localStorage.getItem(firstStartPopupStorageKey) === '1'
+            ) {
+                return;
+            }
+            setActivePopup('on_first_start');
+        };
+
+        instance.addListener(SocketEvent.INSTALL_STARTED, handleInstallStarted);
+        instance.addListener(SocketEvent.STATUS, handleServerStatus);
+
+        return () => {
+            instance.removeListener(SocketEvent.INSTALL_STARTED, handleInstallStarted);
+            instance.removeListener(SocketEvent.STATUS, handleServerStatus);
+        };
+    }, [connected, instance, serverIdentifier, hasFirstStartPopup, activePopup]);
+
+    useEffect(() => {
+        if (!connected || !instance || !hasConsoleErrorPopup) {
+            return;
+        }
+
+        const identifier = String(serverIdentifier);
+        const listener = (line: string) => {
+            if (activePopup || localStorage.getItem(storageKey(identifier, 'on_console_error')) === '1') {
+                return;
+            }
+
+            if (isErrorLikeLine(line)) {
+                setActivePopup('on_console_error');
+            }
+        };
+
+        instance.addListener(SocketEvent.CONSOLE_OUTPUT, listener);
+
+        return () => {
+            instance.removeListener(SocketEvent.CONSOLE_OUTPUT, listener);
+        };
+    }, [connected, instance, hasConsoleErrorPopup, serverIdentifier, activePopup]);
+
+    if (!activePopup) {
+        return null;
+    }
+
+    const title = activePopup === 'on_console_error' ? errorTitle : firstStartTitle;
+    const content = activePopup === 'on_console_error' ? errorContent : firstStartContent;
+
+    const dismiss = () => {
+        localStorage.setItem(storageKey(String(serverIdentifier), activePopup), '1');
+        localStorage.removeItem(powerActionKey(String(serverIdentifier)));
+        hasSeenPowerActionSinceMount.current = false;
+        setActivePopup(null);
+    };
+
+    return (
+        <Modal visible={true} onDismissed={dismiss} closeOnBackground={false}>
+            <h2 css={tw`text-2xl mb-4 text-neutral-100`}>{title || 'Welcome'}</h2>
+            <p css={tw`text-neutral-200 whitespace-pre-line`}>{content || ''}</p>
+            <div css={tw`mt-8 sm:flex items-center justify-end`}>
+                <Button onClick={dismiss} css={tw`w-full sm:w-auto`}>
+                    Continue
+                </Button>
+            </div>
+        </Modal>
+    );
+};
+
+export default FirstRunPopupFeature;
